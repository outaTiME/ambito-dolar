{
  "name": "@ambito-dolar/client",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:ios": "expo prebuild --platform ios --no-clean",
    "lint": "expo lint",
    "eas-build-pre-install": "corepack enable && yarn set version 4",
    "check": "expo install --check"
  },
  "dependencies": {
    "@ambito-dolar/core": "^5.2.0",
    "@amplitude/analytics-react-native": "^1.6.1",
