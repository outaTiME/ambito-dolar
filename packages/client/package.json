    "expo-mail-composer": "~56.0.4",
    "expo-notifications": "~56.0.18",
    "expo-quick-actions": "^6.0.2",
    "expo-router": "~56.2.11",
    "expo-screen-orientation": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
