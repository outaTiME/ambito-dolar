    "react-native-gesture-handler": "^3.0.2",
    "react-native-get-random-values": "^2.0.0",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "~4.3.1",
    "react-native-redash": "^18.1.5",
    "react-native-safe-area-context": "^5.8.0",
